APP_NAME=CitiInfo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=https://citiinfo.com.au

# API server (api.citiinfo.com.au): allow Next.js frontend origins for CORS
# CORS_ALLOWED_ORIGINS=https://citiinfo.com.au,https://www.citiinfo.com.au

# Sanctum SPA auth – frontend domains that send session cookies to /api/*
# SANCTUM_STATEFUL_DOMAINS=citiinfo.com.au,www.citiinfo.com.au,api.citiinfo.com.au,crm.citiinfo.com.au

# Local: use file driver. Production: see bottom of file.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false

# --- Production (api.citiinfo.com.au + Next.js on citiinfo.com.au) ---
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://api.citiinfo.com.au
#
# CORS_ALLOWED_ORIGINS=https://citiinfo.com.au,https://www.citiinfo.com.au
# SANCTUM_STATEFUL_DOMAINS=citiinfo.com.au,www.citiinfo.com.au,api.citiinfo.com.au,crm.citiinfo.com.au
#
# Share login session across citiinfo.com.au ↔ api.citiinfo.com.au ↔ crm.citiinfo.com.au
# SESSION_DOMAIN=.citiinfo.com.au
# SESSION_SECURE_COOKIE=true
#
# If API + CRM are separate servers, use shared session store (not file):
# SESSION_DRIVER=database
# Do NOT set SESSION_DOMAIN=localhost on production.

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=citiinfo
DB_USERNAME=root
DB_PASSWORD=
